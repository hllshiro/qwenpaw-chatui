{
  "name": "star-agent-chatui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "drizzle-kit generate && vite",
    "build": "drizzle-kit generate && pnpm run db:migrate && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "vue-tsc -p ./tsconfig.app.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "husky",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.177",
    "@iconify/vue": "^5.0.1",
    "@libsql/client": "^0.17.3",
    "@nuxt/ui": "^4.7.1",
    "@shikijs/langs": "^4.0.2",
    "@unhead/vue": "^2.1.15",
    "@vueuse/core": "^14.3.0",
    "ai": "^6.0.177",
    "date-fns": "^4.1.0",
    "dayjs": "1.11.20",
    "defu": "^6.1.7",
    "drizzle-orm": "^0.45.2",
    "markstream-vue": "1.0.3-beta.2",
    "nitro": "3.0.260522-beta",
    "ofetch": "^1.5.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "ufo": "^1.6.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  },
  "packageManager": "pnpm@10.33.4"
}
